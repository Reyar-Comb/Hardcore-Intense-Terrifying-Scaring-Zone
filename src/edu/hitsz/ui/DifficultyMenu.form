<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="edu.hitsz.ui.DifficultyMenu">
  <grid id="27dc6" binding="DifficultyPanel" layout-manager="GridBagLayout">
    <constraints>
      <xy x="20" y="20" width="265" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="90ef5" class="javax.swing.JButton" binding="EasyButton">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag weightx="1.0" weighty="1.0"/>
        </constraints>
        <properties>
          <background color="-12341906"/>
          <enabled value="true"/>
          <font name="Maple Mono NF CN" size="26"/>
          <text value="Easy"/>
        </properties>
      </component>
      <component id="385f8" class="javax.swing.JButton" binding="HardButton">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag weightx="1.0" weighty="1.0"/>
        </constraints>
        <properties>
          <background color="-2544101"/>
          <enabled value="true"/>
          <font name="Maple Mono NF CN" size="26"/>
          <foreground color="-16777216"/>
          <text value="Hard"/>
        </properties>
      </component>
      <component id="1fb19" class="javax.swing.JLabel" binding="DifficultyTitle">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag top="50" left="0" bottom="50" right="0" weightx="1.0" weighty="1.0"/>
        </constraints>
        <properties>
          <font name="Maple Mono NF CN" size="26"/>
          <text value="Difficulty"/>
        </properties>
      </component>
      <component id="a177" class="javax.swing.JButton" binding="NormalButton">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag weightx="1.0" weighty="1.0"/>
        </constraints>
        <properties>
          <background color="-4210333"/>
          <font name="Maple Mono NF CN" size="28"/>
          <foreground color="-14976966"/>
          <text value="Normal"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
